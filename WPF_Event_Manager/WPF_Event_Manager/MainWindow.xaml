<Window x:Class="WPF_Event_Manager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
         xmlns:local="clr-namespace:WPF_Event_Manager"
        mc:Ignorable="d"
        Title="Event Registration Manager" Height="650" Width="950">
    <Grid Background="White">

        <!-- Grid Overview Border -->
        <Border BorderBrush="Black"
                BorderThickness="3"
                CornerRadius="10"
                Margin="15"
                Padding="20"
                Background="White">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Heading Border-->
                <Border BorderBrush="ForestGreen"
                        BorderThickness="2"
                        CornerRadius="10"
                        Padding="10"
                        Margin="0,0,0,20"
                        Background="LawnGreen">

                    <TextBlock Text="Event Registration Manager"
                               FontSize="24"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                </Border>

                <!-- Input Section Border-->
                <Border Grid.Row="1"
                        BorderBrush="Gray"
                        BorderThickness="3"
                        CornerRadius="10"
                        Padding="15"
                        Margin="0,0,0,15"
                        Background="White">

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="250"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="250"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Content="Employee Name:"
                               FontWeight="Bold"
                               Grid.Row="0"
                               Grid.Column="0"/>

                        <TextBox x:Name="txtEmployeeName"
                                 FontWeight="Bold"
                                 Grid.Row="0"
                                 Grid.Column="1"
                                 Margin="5"/>

                        <Label Content="Event Name:"
                               FontWeight="Bold"
                               Grid.Row="1"
                               Grid.Column="0"/>

                        <TextBox x:Name="txtEventName"
                                 Grid.Row="1"
                                 Grid.Column="1"
                                 Margin="5"/>

                        <Label Content="Department:"
                               FontWeight="Bold"
                               Grid.Row="2"
                               Grid.Column="0"/>

                        <TextBox x:Name="txtDepartment"
                                 Grid.Row="2"
                                 Grid.Column="1"
                                 Margin="5"/>

                        <Label Content="Fee:"
                               FontWeight="Bold"
                               Grid.Row="0"
                               Grid.Column="2"/>

                        <TextBox x:Name="txtFee"
                                 Grid.Row="0"
                                 Grid.Column="3"
                                 Margin="5"/>

                        <Label Content="Days Attending:"
                               FontWeight="Bold"
                               Grid.Row="1"
                               Grid.Column="2"/>

                        <TextBox x:Name="txtDaysAttending"
                                 Grid.Row="1"
                                 Grid.Column="3"
                                 Margin="5"/>

                        <Label Content="Filter Department:"
                               FontWeight="Bold"
                               Grid.Row="2"
                               Grid.Column="2"/>

                        <TextBox x:Name="txtFilterDepartment"
                                 Grid.Row="2"
                                 Grid.Column="3"
                                 Margin="5"/>

                        <Button Content="Add Registration"
                                Grid.Row="3"
                                Grid.Column="1"
                                Margin="5"
                                Padding="5"
                                Click="btnAdd_Click"/>

                        <Button Content="Filter Department"
                                Grid.Row="3"
                                Grid.Column="3"
                                Margin="5"
                                Padding="5"
                                Click="btnFilterDepartment_Click"/>

                    </Grid>
                </Border>

                <!-- Display Section -->
                <Border Grid.Row="2"
                        BorderBrush="Gray"
                        BorderThickness="3"
                        CornerRadius="10"
                        Padding="10"
                        Background="White">

                    <TextBox x:Name="txtOutput"
                             FontFamily="Calibri"
                             FontSize="14"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             BorderThickness="0"
                             Background="White" TextChanged="txtOutput_TextChanged"/>
                </Border>

                <!-- Button Section -->
                <Border Grid.Row="3"
                        BorderBrush="Gray"
                        BorderThickness="3"
                        CornerRadius="10"
                        Padding="10"
                        Margin="0,15,0,0"
                        Background="White">

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center">

                        <Button Content="Display All"
                                Width="120"
                                Margin="5"
                                Padding="5"
                                Click="btnDisplayAll_Click"/>

                        <Button Content="Needs Approval"
                                Width="130"
                                Margin="5"
                                Padding="5"
                                Click="btnNeedsApproval_Click"/>

                        <Button Content="Summary"
                                Width="120"
                                Margin="5"
                                Padding="5"
                                Click="btnSummary_Click"/>

                        <Button Content="Clear"
                                Width="120"
                                Margin="5"
                                Padding="5"
                                Click="btnClear_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>